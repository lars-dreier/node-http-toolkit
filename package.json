{
	"name": "node-http-toolkit",
	"version": "1.0.1",
	"description": "Resumable, parallel file downloads for Node.js, plus HTTP requests with redirect and decompression handling.",
	"type": "module",
	"types": "./dist/index.d.mts",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"check:exports": "attw --pack .",
		"prepublishOnly": "npm test && npm run typecheck && npm run build && npm run check:exports",
		"dev": "tsdown --watch",
		"test": "tsx --test \"test/**/*.test.ts\"",
		"test:coverage": "tsx --test --experimental-test-coverage \"test/**/*.test.ts\"",
		"test:watch": "tsx --test --watch \"test/**/*.test.ts\"",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "dprint fmt",
		"format:check": "dprint check"
	},
	"keywords": [
		"http",
		"https",
		"download",
		"request",
		"client",
		"node"
	],
	"author": {
		"name": "Lars Dreier",
		"email": "ldreier@posteo.de"
	},
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lars-dreier/node-http-toolkit.git"
	},
	"bugs": {
		"url": "https://github.com/lars-dreier/node-http-toolkit/issues"
	},
	"homepage": "https://github.com/lars-dreier/node-http-toolkit#readme",
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "0.18.3",
		"@eslint/js": "10.0.1",
		"@types/node": "25.9.3",
		"dprint": "0.54.0",
		"eslint": "10.5.0",
		"eslint-config-prettier": "10.1.8",
		"globals": "17.6.0",
		"tsdown": "0.22.2",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"typescript-eslint": "8.61.0"
	}
}
